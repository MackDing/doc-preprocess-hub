# ---- doc-preprocess-hub local dev environment ----
# Copy to .env and adjust for your machine.

# Postgres
POSTGRES_USER=dph
POSTGRES_PASSWORD=dph_dev_password
POSTGRES_DB=dph
POSTGRES_PORT=5432

# Redis (cache + Celery result backend)
REDIS_PORT=6379

# RabbitMQ (Celery broker)
RABBITMQ_USER=dph
RABBITMQ_PASSWORD=dph_dev_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# MinIO (object storage)
MINIO_ROOT_USER=dph
MINIO_ROOT_PASSWORD=dph_dev_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_RAW=dph-raw
MINIO_BUCKET_PARSED=dph-parsed

# orchestrator-api
ORCHESTRATOR_PORT=8000
DATABASE_URL=postgresql+psycopg://dph:dph_dev_password@postgres:5432/dph
CELERY_BROKER_URL=amqp://dph:dph_dev_password@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=dph
MINIO_SECRET_KEY=dph_dev_password
MINIO_SECURE=false

# Auth (dev: trust-all; swap to your OIDC provider in prod)
AUTH_MODE=trust-all
# AUTH_MODE=oidc
# OIDC_ISSUER_URL=https://your-iam.example.com/realms/dph
# OIDC_AUDIENCE=doc-preprocess-hub

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=orchestrator-api
LOG_LEVEL=INFO
